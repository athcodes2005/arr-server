{
	email {$LETSENCRYPT_EMAIL}
}

# Explicit HTTP catch-all that redirects to the CANONICAL HTTPS domain.
# This prevents host-header injection: Caddy's default auto-HTTPS redirect
# reflects the request Host header into the Location URL, letting an attacker
# craft a redirect to an arbitrary domain. Hardcoding {$DOMAIN} here fixes it.
http:// {
	redir https://{$DOMAIN}{uri} 308
}

{$DOMAIN} {
	# Compress text-based responses (HTML, JSON, XML, subtitles).
	# Explicitly exclude /webdav/* — video files are already compressed codecs
	# (H.264/H.265) and the encode middleware buffers an initial chunk on every
	# response to decide whether compression applies, which causes seek stalls
	# when a video player issues Range requests against large files.
	@compressible not path /webdav /webdav/*
	encode @compressible zstd gzip

	header {
		# HSTS: tell browsers to always use HTTPS for this domain (1 year).
		# preload allows submission to the browser preload lists.
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"

		# Prevent clickjacking and restrict access to sensitive browser APIs.
		Cross-Origin-Opener-Policy "same-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"

		# Strip backend fingerprinting headers added by upstream apps.
		# Upstream "Server: Kestrel" (.NET), "Server: waitress" (Python),
		# and Next.js's "X-Powered-By" are removed; Caddy's own "Server: Caddy"
		# is also suppressed so scanners cannot fingerprint the stack.
		-Server
		-X-Powered-By
	}

	redir /qbittorrent /qbittorrent/ 308
	handle_path /qbittorrent/* {
		reverse_proxy qbittorrent:8080 {
			header_up Host qbittorrent:8080
			header_up Origin http://qbittorrent:8080
			header_up Referer http://qbittorrent:8080
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	@prowlarr path /prowlarr /prowlarr/*
	handle @prowlarr {
		reverse_proxy prowlarr:9696
	}

	@sonarr path /sonarr /sonarr/*
	handle @sonarr {
		reverse_proxy sonarr:8989
	}

	@radarr path /radarr /radarr/*
	handle @radarr {
		reverse_proxy radarr:7878
	}

	@bazarr path /bazarr /bazarr/*
	handle @bazarr {
		reverse_proxy bazarr:6767 {
			# Bazarr emits Access-Control-Allow-Origin: * (and reflects arbitrary
			# Origin values) regardless of its internal cors: enabled: false setting.
			# Strip all CORS response headers here — the service is only ever
			# accessed same-origin through Caddy and needs no CORS at all.
			header_down -Access-Control-Allow-Origin
			header_down -Access-Control-Allow-Methods
			header_down -Access-Control-Allow-Headers
			header_down -Access-Control-Allow-Credentials
			header_down -Access-Control-Expose-Headers
			header_down -Access-Control-Max-Age
		}
	}

	# WebDAV share of the media library. The server itself is configured with
	# prefix: /webdav, so we forward the path intact (no handle_path strip).
	# The backend now serves both a browser UI and WebDAV from the same route.
	# flush_interval -1 enables Caddy's low-latency mode for ranged video
	# streaming, disabling proxy response buffering on this path.
	@webdav path /webdav /webdav/*
	handle @webdav {
		reverse_proxy webdav:6065 {
			flush_interval -1
		}
	}

	handle {
		reverse_proxy homepage:3000
	}
}
