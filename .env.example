COMPOSE_PROJECT_NAME=arr-server

# LinuxServer UID/GID settings
PUID=1000
PGID=1000
TZ=Asia/Kolkata
UMASK=002

# Public endpoint
DOMAIN=yourhost.duckdns.org
LETSENCRYPT_EMAIL=your-email@example.com

# DuckDNS auto-updater. Token from https://www.duckdns.org (signed in).
# Leave blank to disable the updater (and manage AAAA records manually).
DUCKDNS_TOKEN=

# Docker network ranges used by the IPv6-enabled bridge network
DOCKER_IPV4_SUBNET=172.31.10.0/24
DOCKER_IPV6_SUBNET=fd42:4242:4242::/64

# Mac -> Pi deployment settings
PI_SSH_HOST=youruser@yourhost.duckdns.org
PI_DEPLOY_PATH=/home/youruser/arr-server

# qBittorrent
QBITTORRENT_WEBUI_PORT=8080
QBITTORRENT_TORRENT_PORT=6881
QBITTORRENT_WEBUI_USERNAME=admin
QBITTORRENT_WEBUI_PASSWORD=change-me
QBITTORRENT_TRACKER_LIST_URL=https://raw.githubusercontent.com/ngosang/trackerslist/master/trackers_all.txt

# Servarr auth for Prowlarr / Sonarr / Radarr.
# If omitted, bootstrap falls back to the qBittorrent username and password above.
ARR_AUTH_USERNAME=admin
ARR_AUTH_PASSWORD=change-me

# Homepage widget API keys
# Fill these in after first boot by copying the keys from each app UI.
PROWLARR_API_KEY=
SONARR_API_KEY=
RADARR_API_KEY=
BAZARR_API_KEY=

# WebDAV read-only share of ./data/media. These are the credentials other
# devices (Finder, VLC, Kodi, etc.) will use to connect to
# https://${DOMAIN}/webdav/.
WEBDAV_USERNAME=media
WEBDAV_PASSWORD=change-me
